# Copy this file to .env and fill in values.

# Azure Blob Storage — required for CGM data (stage 6)
AZURE_ACCOUNT_NAME=your_storage_account_name
AZURE_CONTAINER_NAME=your_container_name
AZURE_DATASET_PREFIX=your_dataset_prefix
AZURE_SAS_TOKEN=your_sas_token

# Optional: override the local CGM data cache directory (default: ./data/cache)
# TSLM_CACHE_DIR=/path/to/cache

# OpenAI API Key — required only for generating GPT-4o captions
# Not needed for training or evaluation once captions.json exists
# Can use with templated CoT rationales instead
OPENAI_API_KEY=sk-...
